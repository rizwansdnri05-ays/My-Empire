<!DOCTYPE html>
<html>
<head>
<title>Khan's Prince</title>

<style>
body {
  margin:0;
  font-family:Arial;
  background:#0b0b0b;
  color:white;
}

/* HEADER */
header {
  text-align:center;
  padding:20px;
  background:black;
}

h1 {
  color:gold;
}

/* GRID LAYOUT */
.container {
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(180px,1fr));
  gap:20px;
  padding:20px;
}

/* PRODUCT CARD */
.product {
  background:#111;
  padding:15px;
  border-radius:12px;
  text-align:center;
  transition:0.3s;
}

.product:hover {
  transform:scale(1.05);
}

/* IMAGE */
.product img {
  width:100%;
  border-radius:10px;
}

/* BUTTON */
button {
  background:gold;
  border:none;
  padding:10px;
  margin-top:10px;
  cursor:pointer;
  border-radius:5px;
}
</style>

</head>

<body>

<header>
  <h1>Khan's Prince</h1>
  <p>Premium Fashion Store</p>
</header>

<div class="container">

  <div class="product">
    <img src="https://i.imgur.com/abcd123.jpg">
    <h3>Designer Shirt</h3>
    <p>₹999</p>
    <button>Buy Now</button>
  </div>

  <div class="product">
    <img src="https://i.imgur.com/abcd123.jpg">
    <h3>Stylish Pant</h3>
    <p>₹1499</p>
    <button>Buy Now</button>
  </div>

  <div class="product">
    <img src="https://i.imgur.com/abcd123.jpg">
    <h3>Premium T-Shirt</h3>
    <p>₹799</p>
    <button>Buy Now</button>
  </div>

</div>

</body>
</html>